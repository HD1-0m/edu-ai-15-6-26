rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Global Safety Net default catch-all: forbid everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: checks if user is authenticated and matches the requested resource subpath
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Match blocks for secure, isolated entities
    match /users/{userId} {
      allow read, get, list: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /chats/{chatId} {
        allow read, get, list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      match /notes/{noteId} {
        allow read, get, list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      match /folders/{folderId} {
        allow read, get, list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      match /quizzes/{quizId} {
        allow read, get, list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }
  }
}
